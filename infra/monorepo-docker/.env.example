# compose ports
BACKEND_PORT=3000
FRONTEND_PORT=3040
KAFKA_UI_PORT=8080

# service-level env override files (optional)
BACKEND_ENV_FILE=../../packages/backend/.env
FRONTEND_ENV_FILE=../../packages/frontend/.env.local

# backend runtime defaults
BACKEND_DATABASE_URL=file:./data/dev.db
METRICS_PASSWORD=Basic base64_secret=

# frontend build-time env (NEXT_PUBLIC_*)
NEXT_PUBLIC_PISSYKAKA_API=https://scheoble.xyz/api
NEXT_PUBLIC_EPDS_API=http://localhost:3000/api
NEXT_PUBLIC_DEFAULT_LIMIT=20
NEXT_PUBLIC_FRONT_BASEURL=http://localhost:3040
NEXT_PUBLIC_PAGINATOR_MAX_ITEMS=10
NEXT_PUBLIC_CHAN_NAME=localhost_umechan
NEXT_PUBLIC_FEATURE_FLAG_MODERKA=true

# optional kafka-ui profile settings
KAFKA_CLUSTER_NAME=default
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_PROPERTIES_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_PROPERTIES_SASL_MECHANISM=
KAFKA_SASL_JAAS_CONFIG=
